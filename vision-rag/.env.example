# ═══════════════════════════════════════════════════════
#  Vision-RAG Multi-Model System — Environment Configuration
# ═══════════════════════════════════════════════════════

# ── HuggingFace (required for model download) ────────
HF_TOKEN=hf_your_token_here

# ── API Authentication (optional) ────────────────────
# Set this to require API key for all requests
# API_KEY=your-secret-api-key

# ── Debug Mode ───────────────────────────────────────
DEBUG=false

# ── CORS (comma-separated origins) ──────────────────
# Empty = no CORS allowed (safe default). Set to * only for local dev.
# CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]

# ── Model Backend URLs (Docker override) ─────────────
# These are auto-configured in Docker Compose.
# Override only for local development.
# COLPALI_URL=http://localhost:8001
# QWEN3VL_URL=http://localhost:8002
# QWEN25_URL=http://localhost:8003

# ── Upload Limits ──────────────────────────────────
# MAX_UPLOAD_SIZE_MB=100

# ── Infrastructure ───────────────────────────────────
# IMPORTANT: Change all default passwords before deployment
POSTGRES_PASSWORD=changeme
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
GRAFANA_PASSWORD=changeme

# ── Rate Limiting ────────────────────────────────────
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60
